{
  "name": "recappi",
  "version": "0.1.0",
  "private": false,
  "bin": {
    "recappi": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "build:helper": "../../scripts/build-cli-helper.sh",
    "test": "vp test",
    "typecheck": "tsc --noEmit",
    "check": "pnpm run typecheck && pnpm run test && pnpm run build",
    "lint:package": "publint run --strict && attw --pack . --no-emoji",
    "pack:check": "pnpm run build && node scripts/check-pack.mjs && pnpm run lint:package"
  },
  "dependencies": {
    "better-sqlite3": "12.10.1",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "ink": "^7.1.0",
    "music-metadata": "^11.10.3",
    "react": "^19.2.7"
  },
  "optionalDependencies": {
    "recappi-helper-darwin-arm64": "0.1.0"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.4",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.17",
    "ink-testing-library": "^4.0.0",
    "publint": "^0.3.21",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=20"
  }
}
